# Copy to /etc/server-agent/agent.env on the server.
PORT=8080
HOST=127.0.0.1
NODE_ENV=production
LOG_LEVEL=info
DB_PATH=/var/lib/server-agent/db/main.sqlite
SESSION_COOKIE_SECRET=replace-with-32-byte-random-secret
ANTHROPIC_AUTH_TOKEN=replace-with-aiwoo-claude-key
OPENAI_API_KEY=replace-with-aiwoo-codex-key
AIWOO_BASE_URL=https://aiwoo.vip
DEFAULT_PROVIDER=aiwoo-claude
DEFAULT_MODEL=claude-opus-4-8
UPSTREAM_FIRST_BYTE_TIMEOUT_MS=30000
